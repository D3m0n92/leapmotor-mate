# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicit text files
*.py        text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.jsx       text eol=lf
*.tsx       text eol=lf
*.vue       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.htm       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.xml       text eol=lf
*.svg       text eol=lf
*.env       text eol=lf
*.sh        text eol=lf
*.bash      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.toml      text eol=lf
*.conf      text eol=lf
*.dockerfile text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf
*.gitignore text eol=lf

# Binary files (no conversion)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.mp4       binary
*.webm      binary
*.mp3       binary
*.wav       binary
*.sqlite3   binary
*.db        binary
*.pem       binary
*.key       binary
*.crt       binary
